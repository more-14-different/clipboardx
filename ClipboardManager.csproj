<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Release：无控制台；Debug：Exe 以便 dotnet run 时附带控制台，避免误以为「没起来」 -->
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>ClipboardManager</RootNamespace>

    <!-- Flavor: Full (默认) / ClipboardOnly / FileJumpOnly -->
    <ClipboardXProduct Condition="'$(ClipboardXProduct)' == ''">Full</ClipboardXProduct>

    <AssemblyName Condition="'$(ClipboardXProduct)' == 'Full'">ClipboardX</AssemblyName>
    <AssemblyName Condition="'$(ClipboardXProduct)' == 'ClipboardOnly'">ClipboardX-clipboard</AssemblyName>
    <AssemblyName Condition="'$(ClipboardXProduct)' == 'FileJumpOnly'">ClipboardX-filejump</AssemblyName>

    <Version>1.6.1</Version>
    <Product>ClipboardX</Product>
    <Company>ClipboardX</Company>
    <RepositoryUrl>https://github.com/chaojimct/clipboardx</RepositoryUrl>
    <ApplicationIcon>assets\clipboard.ico</ApplicationIcon>
    <!-- 多显示器不同缩放时，PerMonitorV2 与 WM_DPICHANGED 配合；避免跨屏拖动时错位/缩放突变 -->
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
  </PropertyGroup>

  <!-- 条件编译符号 -->
  <PropertyGroup Condition="'$(ClipboardXProduct)' == 'Full'">
    <DefineConstants>$(DefineConstants);CLIPX_FULL;CLIPX_CLIPBOARD;CLIPX_FILEJUMP</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(ClipboardXProduct)' == 'ClipboardOnly'">
    <DefineConstants>$(DefineConstants);CLIPX_CLIPBOARD</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(ClipboardXProduct)' == 'FileJumpOnly'">
    <DefineConstants>$(DefineConstants);CLIPX_FILEJUMP</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <!-- FileJumpOnly 仍引用：避免与 PopupWindow 中 ClipboardHistoryStore 脱节；该构建不加载剪贴板 UI，历史库基本闲置 -->
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.11" />
    <PackageReference Include="NPinyin.Core" Version="3.0.0" />
    <PackageReference Include="Svg" Version="3.4.7" />
  </ItemGroup>

  <!-- tools/ 内为独立小工具，勿随主工程一并编译 -->
  <!-- ClipboardX/ 为独立 Avalonia 解决方案，与根目录 WPF 无关；勿纳入默认 **\*.cs 扫描 -->
  <ItemGroup>
    <Compile Remove="tools\**\*" />
    <Compile Remove="ClipboardX\**\*" />
    <Compile Remove="artifacts\**\*" />
  </ItemGroup>

  <!-- 原生 Shell 跳转 DLL：须 Link 到输出根目录（与 ShellDialogDeepNavigate 用 BaseDirectory\*.dll 解析一致）；否则默认会落在 native\...\bin\... 子目录下单文件解压后仍找不到 -->
  <ItemGroup Condition="'$(ClipboardXProduct)' != 'ClipboardOnly'">
    <None Include="native\ShellNavigate\bin\x64\Release\ClipboardXShellNavigate.dll" Link="ClipboardXShellNavigate.dll" CopyToOutputDirectory="PreserveNewest" Condition="Exists('native\ShellNavigate\bin\x64\Release\ClipboardXShellNavigate.dll')" />
    <None Include="native\ShellNavigate\bin\Win32\Release\ClipboardXShellNavigate32.dll" Link="ClipboardXShellNavigate32.dll" CopyToOutputDirectory="PreserveNewest" Condition="Exists('native\ShellNavigate\bin\Win32\Release\ClipboardXShellNavigate32.dll')" />
    <!-- voidtools SDK：与程序集同目录加载；见 native\ 下说明 -->
    <None Include="native\Everything64.dll" Link="Everything64.dll" CopyToOutputDirectory="PreserveNewest" Condition="Exists('native\Everything64.dll')" />
  </ItemGroup>

</Project>
