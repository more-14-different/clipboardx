<Window x:Class="ClipboardManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="ClipboardX - 设置"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="400"
        MinHeight="480"
        Width="440"
        Height="600"
        Background="{DynamicResource WindowBgBrush}">

    <Window.Resources>
        <!-- 系统默认 TabControl 内容区为浅色，暗色主题会「外深内白」且标签对比度差；覆盖模板与标签页样式 -->
        <Style x:Key="SettingsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource WindowBgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid ClipToBounds="True" KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      Panel.ZIndex="1"
                                      Margin="0,0,0,-1"
                                      IsItemsHost="True"
                                      Background="Transparent"
                                      KeyboardNavigation.TabIndex="0" />
                            <Border Grid.Row="1"
                                    Background="{DynamicResource WindowBgBrush}"
                                    BorderBrush="{DynamicResource ThemeBorder}"
                                    BorderThickness="1"
                                    CornerRadius="0,6,6,6"
                                    KeyboardNavigation.DirectionalNavigation="Contained"
                                    KeyboardNavigation.TabNavigation="Local">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Margin="0"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="Background" Value="{DynamicResource FooterBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter x:Name="HeaderSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource WindowBgBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,0" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 仅纵向滚动条美化为圆角细条；横向仍用系统默认（避免误伤横向滚动条布局） -->
        <Style TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="OverridesDefaultStyle" Value="True" />
                    <Setter Property="Width" Value="11" />
                    <Setter Property="MinWidth" Value="11" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Root" Background="Transparent" SnapsToDevicePixels="True">
                                    <Border x:Name="TrackPad"
                                            Width="7"
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource ScrollBarTrackBrush}"
                                            CornerRadius="4"
                                            Margin="0,8" />
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}"
                                                          Opacity="0" Focusable="False" Height="1" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Width="7"
                                                                HorizontalAlignment="Center"
                                                                Background="{DynamicResource ScrollBarThumbBrush}"
                                                                CornerRadius="4"
                                                                Margin="0,2" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBorder"
                                                                        Property="Background"
                                                                        Value="{DynamicResource ScrollBarThumbHoverBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbBorder"
                                                                        Property="Background"
                                                                        Value="{DynamicResource ScrollBarThumbHoverBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}"
                                                          Opacity="0" Focusable="False" Height="1" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs"
                    Grid.Row="0"
                    Margin="12,12,12,8"
                    Style="{StaticResource SettingsTabControlStyle}"
                    Foreground="{DynamicResource PrimaryText}">

            <TabItem x:Name="ClipboardTab" Header="剪贴板">
                <TabItem.Resources>
                    <sys:String x:Key="ClipboardHelp_BatchMerge_Body">开启时：全部纯文本会合并成一段一次粘贴。若和图片、文件等混合，则只合并「彼此相邻」的纯文本段，非文本仍分段粘贴。关闭则每条分段粘贴，目标里通常可多步撤销。普通模式下多选按 Enter 为顺序连贴，按住 Ctrl 可在每条文本后追加换行（合并与逐条均生效）。FIFO/LIFO 模式下多选 Enter 为入队而不立即连贴；在他处每次 Ctrl+V 或 Shift+Insert 会出队一条并把下一项写入剪贴板。</sys:String>
                    <sys:String x:Key="ClipboardHelp_BatchQueueAutoNormal_Body">FIFO / LIFO：队列中条目在他处已全部粘贴完毕（队列为空）后，再按一次 Ctrl+V 或 Shift+Insert 时自动切回「普通」批量模式，避免长期停留在队列模式。关闭则队列为空后仍保持当前 FIFO 或 LIFO，需手动切换模式。</sys:String>
                    <Style x:Key="ClipboardHelpGlyphLabel" TargetType="Label">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="6,0,0,0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="MinWidth" Value="18" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentBg}" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
                        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
                    </Style>
                    <ToolTip x:Key="ClipboardTipBatchMerge" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource ClipboardHelp_BatchMerge_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="ClipboardTipBatchQueueAutoNormal" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource ClipboardHelp_BatchQueueAutoNormal_Body}" />
                    </ToolTip>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4,0,0"
                              ToolTipService.InitialShowDelay="0"
                              ToolTipService.BetweenShowDelay="0"
                              ToolTipService.ShowDuration="60000">
                    <Grid Margin="16,10,16,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="剪贴板面板" FontSize="18"
                                   FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="最大记录数"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="MaxItemsBox" Grid.Row="2" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="呼出快捷键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border x:Name="HotkeyBox" Grid.Row="4" Grid.Column="1"
                                HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" Focusable="True"
                                MouseLeftButtonUp="HotkeyBox_Click"
                                PreviewKeyDown="HotkeyBox_KeyDown"
                                LostFocus="HotkeyBox_LostFocus">
                            <TextBlock x:Name="HotkeyText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="批量模式切换键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border x:Name="BatchModeCycleHotkeyBox" Grid.Row="6" Grid.Column="1"
                                HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" Focusable="True"
                                MouseLeftButtonUp="BatchModeCycleHotkeyBox_Click"
                                PreviewKeyDown="BatchModeCycleHotkeyBox_KeyDown"
                                LostFocus="BatchModeCycleHotkeyBox_LostFocus">
                            <TextBlock x:Name="BatchModeCycleHotkeyText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="外观主题"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="8" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ThemeCycle_Click">
                            <TextBlock x:Name="ThemeText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="弹出位置"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="10" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="PositionCycle_Click">
                            <TextBlock x:Name="PositionText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="点击外部隐藏"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="12" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ClickHideCycle_Click">
                            <TextBlock x:Name="ClickHideText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="不透明度"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="14" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Slider x:Name="OpacitySlider" Width="100" Minimum="0.4" Maximum="1.0"
                                    Value="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="OpacitySlider_ValueChanged" />
                            <TextBlock x:Name="OpacityValueText" Foreground="{DynamicResource SecondaryText}"
                                       FontSize="13" VerticalAlignment="Center" MinWidth="40" TextAlignment="Right" Margin="6,0,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Row="16" Grid.Column="0" Text="预览行数"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="PreviewLinesBox" Grid.Row="16" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}" />

                        <TextBlock Grid.Row="17" Grid.Column="0" Text="粘贴模式"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="17" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="PasteSimulationCycle_Click"
                                ToolTip="写入剪贴板后向目标窗口模拟的按键；部分程序对 Ctrl+V 与 Shift+Insert 表现不同">
                            <TextBlock x:Name="PasteSimulationText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="18" Grid.Column="0" Text="面板主键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="18" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ModifierCycle_Click">
                            <TextBlock x:Name="ModifierText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="26" Grid.Column="0" Text="向上翻页快捷键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border x:Name="PanelPageUpKeyBox" Grid.Row="26" Grid.Column="1"
                                HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" Focusable="True"
                                MouseLeftButtonUp="PanelPageUpKeyBox_Click"
                                PreviewKeyDown="PanelPageUpKeyBox_KeyDown"
                                LostFocus="PanelPageUpKeyBox_LostFocus"
                                ToolTip="点击后按下组合键（须含 Ctrl/Shift/Alt/Win 之一），默认 Ctrl+-">
                            <TextBlock x:Name="PanelPageUpKeyText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="28" Grid.Column="0" Text="向下翻页快捷键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border x:Name="PanelPageDownKeyBox" Grid.Row="28" Grid.Column="1"
                                HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" Focusable="True"
                                MouseLeftButtonUp="PanelPageDownKeyBox_Click"
                                PreviewKeyDown="PanelPageDownKeyBox_KeyDown"
                                LostFocus="PanelPageDownKeyBox_LostFocus"
                                ToolTip="点击后按下组合键（须含修饰键），默认 Ctrl+=">
                            <TextBlock x:Name="PanelPageDownKeyText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="20" Grid.Column="0" Text="面板宽度 (px)"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="PopupWidthBox" Grid.Row="20" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}"
                                 ToolTip="剪贴板弹窗宽度（DIP），建议 280～1200" />

                        <TextBlock Grid.Row="22" Grid.Column="0" Text="面板最大高度 (px)"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="PopupMaxHeightBox" Grid.Row="22" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}"
                                 ToolTip="列表区域最大高度（DIP），建议 200～900" />

                        <TextBlock Grid.Row="24" Grid.Column="0" Text="每次翻页条数"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="PopupPageItemsBox" Grid.Row="24" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}"
                                 ToolTip="与 PgUp/Dn、←→ 及下方翻页快捷键一致，每次滚动的条目数（1～50）" />

                        <TextBlock Grid.Row="30" Grid.Column="0" Text="开机自启动"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="30" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="StartupCycle_Click">
                            <TextBlock x:Name="StartupText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="32" Grid.Column="0" Text="以管理员身份启动"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="32" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="RunAsAdminCycle_Click"
                                ToolTip="开启后每次启动会弹出 UAC；若取消则仍以普通权限运行。开机自启亦会请求提升。">
                            <TextBlock x:Name="RunAsAdminText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="34" Grid.Column="0" Text="启动时检查更新"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="34" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="CheckUpdateOnStartupCycle_Click">
                            <TextBlock x:Name="CheckUpdateOnStartupText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="36" Grid.Column="0" Text="替换系统 Win+V"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center"
                                   ToolTip="拦截系统剪贴板历史快捷键，改为打开 ClipboardX" />
                        <Border Grid.Row="36" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ReplaceSystemWinV_Click"
                                ToolTip="开启后，按 Win+V 将打开 ClipboardX 而不是系统剪贴板历史">
                            <TextBlock x:Name="ReplaceSystemWinVText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="38" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource ClipboardTipBatchMerge}">
                                <TextBlock Text="文本批量合并粘贴" Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                            </Border>
                            <Label Content="?" Style="{StaticResource ClipboardHelpGlyphLabel}"
                                   ToolTip="{StaticResource ClipboardTipBatchMerge}" />
                        </StackPanel>
                        <Border Grid.Row="38" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="BatchPasteMergeCycle_Click"
                                ToolTip="{StaticResource ClipboardTipBatchMerge}">
                            <TextBlock x:Name="BatchPasteMergeToggleText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="40" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource ClipboardTipBatchQueueAutoNormal}">
