<Window x:Class="ClipboardManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="ClipboardX - 设置"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="400"
        MinHeight="480"
        Width="440"
        Height="560"
        Background="{DynamicResource WindowBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs"
                    Grid.Row="0"
                    Margin="12,12,12,8"
                    Foreground="{DynamicResource PrimaryText}">

            <TabItem Header="剪贴板">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4,0,0">
                    <Grid Margin="16,10,16,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="剪贴板面板" FontSize="18"
                                   FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="最大记录数"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="MaxItemsBox" Grid.Row="2" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="呼出快捷键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border x:Name="HotkeyBox" Grid.Row="4" Grid.Column="1"
                                HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" Focusable="True"
                                MouseLeftButtonUp="HotkeyBox_Click"
                                PreviewKeyDown="HotkeyBox_KeyDown"
                                LostFocus="HotkeyBox_LostFocus">
                            <TextBlock x:Name="HotkeyText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="外观主题"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ThemeCycle_Click">
                            <TextBlock x:Name="ThemeText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="弹出位置"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="8" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="PositionCycle_Click">
                            <TextBlock x:Name="PositionText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="点击外部隐藏"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="10" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ClickHideCycle_Click">
                            <TextBlock x:Name="ClickHideText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="透明度"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Slider x:Name="OpacitySlider" Width="100" Minimum="0.4" Maximum="1.0"
                                    Value="0.95" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="OpacitySlider_ValueChanged" />
                            <TextBlock x:Name="OpacityValueText" Foreground="{DynamicResource SecondaryText}"
                                       FontSize="13" VerticalAlignment="Center" Width="36" TextAlignment="Right" Margin="6,0,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="预览行数"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <TextBox x:Name="PreviewLinesBox" Grid.Row="14" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}" />

                        <TextBlock Grid.Row="16" Grid.Column="0" Text="面板主键"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="16" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ModifierCycle_Click">
                            <TextBlock x:Name="ModifierText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="18" Grid.Column="0" Text="开机自启动"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="18" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="StartupCycle_Click">
                            <TextBlock x:Name="StartupText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="20" Grid.Column="0" Text="启动时检查更新"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="14" VerticalAlignment="Center" />
                        <Border Grid.Row="20" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="CheckUpdateOnStartupCycle_Click">
                            <TextBlock x:Name="CheckUpdateOnStartupText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <Button Grid.Row="22" Grid.ColumnSpan="2" Content="🗑 清空所有历史记录"
                                HorizontalAlignment="Left" Height="34" Padding="16,0"
                                FontSize="13" Background="{DynamicResource DangerBg}" Foreground="White"
                                BorderBrush="Transparent" Cursor="Hand" Click="ClearHistory_Click" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="文件夹跳转">
                <TabItem.Resources>
                    <sys:String x:Key="FolderJumpHelp_Hotkey_Title">文件对话框跳转键</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Hotkey_Body">点击右侧区域后，按下要绑定的组合键。须与「剪贴板」页里的呼出快捷键不同。</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Delay_Title">跳转列表延时 (ms)</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Delay_Body">0 表示立即弹出；延时内再按一次跳转键会直接跳到预选路径。</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Follow_Title">跳转列表跟随</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Follow_Body">跟随对话框：列表紧贴文件对话框并随窗口移动。跟随鼠标：列表在鼠标附近弹出。</sys:String>
                    <sys:String x:Key="FolderJumpHelp_MultiPopup_Title">多候选时弹出列表</sys:String>
                    <sys:String x:Key="FolderJumpHelp_MultiPopup_Body">多候选路径时：开＝弹出跳转列表供选择；关＝直接跳到当前最优路径。快捷键与下面「对话框到前台自动执行」共用这一条规则。</sys:String>
                    <sys:String x:Key="FolderJumpHelp_OpenFg_Title">对话框到前台自动执行</sys:String>
                    <sys:String x:Key="FolderJumpHelp_OpenFg_Body">开：检测到打开/保存对话框到前台时，无需按快捷键即走「多候选时弹出列表」这一条（多候选弹列表或直跳、单候选直跳）。关：只能靠快捷键。同一对话框顶层窗口只自动处理一次。说明：开启本项时，跳转列表始终紧贴文件对话框并随窗口移动（不受「跳转列表跟随」里「跟随鼠标」影响）；仅用快捷键打开列表时，仍按「跟随对话框/鼠标」。</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Shell_Title">Shell 注入跳转</sys:String>
                    <sys:String x:Key="FolderJumpHelp_Shell_Body">开启时优先注入宿主进程用 IShellBrowser 切换目录（仅系统公共对话框）。关闭则仅用地址栏/键入模拟，可减少杀软误报或宿主拦截导致的问题。</sys:String>
                    <sys:String x:Key="FolderJumpHelp_AutoClick_Title">点击后自动跳转</sys:String>
                    <sys:String x:Key="FolderJumpHelp_AutoClick_Body">打开/保存对话框成为前台后，第一次在该对话框内点击左键时自动跳到候选列表第一条；同一对话框窗口存续期内只自动跳一次（关掉再开才会再次触发）。多候选跳转列表打开期间不触发。</sys:String>
                    <Style x:Key="FolderJumpHelpGlyphLabel" TargetType="Label">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="6,0,0,0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="MinWidth" Value="18" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
                        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
                    </Style>
                    <ToolTip x:Key="FolderJumpTipHotkey" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_Hotkey_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="FolderJumpTipFollow" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_Follow_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="FolderJumpTipMultiPopup" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_MultiPopup_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="FolderJumpTipOpenForeground" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_OpenFg_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="FolderJumpTipShell" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_Shell_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="FolderJumpTipAutoClick" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_AutoClick_Body}" />
                    </ToolTip>
                    <ToolTip x:Key="FolderJumpTipDelay" x:Shared="False" MaxWidth="420" Padding="10,8"
                             Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource ThemeBorder}"
                             BorderThickness="1">
                        <TextBlock FontSize="13" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"
                                   Text="{StaticResource FolderJumpHelp_Delay_Body}" />
                    </ToolTip>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4,0,0"
                              ToolTipService.InitialShowDelay="0"
                              ToolTipService.BetweenShowDelay="0"
                              ToolTipService.ShowDuration="60000">
                    <Grid Margin="16,10,16,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
                            <TextBlock Text="打开/保存 对话框跳转" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}" />
                            <TextBlock Margin="0,4,0,0" FontSize="12" Opacity="0.72" TextWrapping="Wrap"
                                       Foreground="{DynamicResource PrimaryText}"
                                       Text="提示：鼠标悬停在「?」、标签文字或右侧开关上可立即查看说明，移开即关闭。" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="文件对话框跳转键" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       VerticalAlignment="Center" />
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipHotkey}" />
                        </StackPanel>
                        <Border x:Name="FileJumpHotkeyBox" Grid.Row="2" Grid.Column="1"
                                HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" Focusable="True"
                                MouseLeftButtonUp="FileJumpHotkeyBox_Click"
                                PreviewKeyDown="FileJumpHotkeyBox_KeyDown"
                                LostFocus="FileJumpHotkeyBox_LostFocus">
                            <TextBlock x:Name="FileJumpHotkeyText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource FolderJumpTipDelay}">
                                <TextBlock Text="跳转列表延时 (ms)" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipDelay}" />
                        </StackPanel>
                        <TextBox x:Name="FileJumpDelayMsBox" Grid.Row="4" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 ToolTip="{StaticResource FolderJumpTipDelay}"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}" />

                        <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource FolderJumpTipFollow}">
                                <TextBlock Text="跳转列表跟随" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipFollow}" />
                        </StackPanel>
                        <Border Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="FileJumpFollowCycle_Click"
                                ToolTip="{StaticResource FolderJumpTipFollow}">
                            <TextBlock x:Name="FileJumpFollowText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="8" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource FolderJumpTipMultiPopup}">
                                <TextBlock Text="多候选时弹出列表" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipMultiPopup}" />
                        </StackPanel>
                        <Border Grid.Row="8" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="FileJumpAutoPopupCycle_Click"
                                ToolTip="{StaticResource FolderJumpTipMultiPopup}">
                            <TextBlock x:Name="FileJumpAutoPopupText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="10" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource FolderJumpTipOpenForeground}">
                                <TextBlock Text="对话框到前台自动执行" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipOpenForeground}" />
                        </StackPanel>
                        <Border Grid.Row="10" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="FileJumpOpenOnForegroundCycle_Click"
                                ToolTip="{StaticResource FolderJumpTipOpenForeground}">
                            <TextBlock x:Name="FileJumpOpenOnForegroundText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="12" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource FolderJumpTipShell}">
                                <TextBlock Text="Shell 注入跳转" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipShell}" />
                        </StackPanel>
                        <Border Grid.Row="12" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ShellInjectCycle_Click"
                                ToolTip="{StaticResource FolderJumpTipShell}">
                            <TextBlock x:Name="ShellInjectText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="14" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource FolderJumpTipAutoClick}">
                                <TextBlock Text="点击后自动跳转" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource FolderJumpHelpGlyphLabel}"
                                   ToolTip="{StaticResource FolderJumpTipAutoClick}" />
                        </StackPanel>
                        <Border Grid.Row="14" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="FileJumpAutoClickCycle_Click"
                                ToolTip="{StaticResource FolderJumpTipAutoClick}">
                            <TextBlock x:Name="FileJumpAutoClickText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="自定义文件对话框">
                <Grid Margin="16,12,16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" MinHeight="160" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Foreground="{DynamicResource PrimaryText}"
                               TextWrapping="Wrap"
                               Text="针对内置识别为「无」的文件对话框：按窗口类名与进程名匹配。导入/导出为 JSON；合并导入时相同键的规则会被覆盖。探测向导也可从托盘菜单运行。" />

                    <ListBox x:Name="CustomRulesList"
                             Grid.Row="2"
                             Foreground="{DynamicResource PrimaryText}"
                             Background="{DynamicResource SurfaceBrush}"
                             BorderBrush="{DynamicResource ThemeBorder}"
                             DisplayMemberPath="SummaryLine" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button Content="删除所选"
                                Padding="12,6" MinWidth="100"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleDelete_Click" Cursor="Hand" />
                        <Button Content="运行探测向导…"
                                Padding="12,6" MinWidth="120" Margin="10,0,0,0"
                                Background="{DynamicResource AccentBg}"
                                Foreground="{DynamicResource AccentFg}"
                                BorderBrush="Transparent"
                                Click="CustomRuleWizard_Click" Cursor="Hand" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                        <Button Content="导入（合并）"
                                Padding="10,6" MinWidth="100"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleImportMerge_Click" Cursor="Hand" />
                        <Button Content="导入（替换）"
                                Padding="10,6" MinWidth="100" Margin="8,0,0,0"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleImportReplace_Click" Cursor="Hand" />
                        <Button Content="导出全部…"
                                Padding="10,6" MinWidth="100" Margin="8,0,0,0"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleExport_Click" Cursor="Hand" />
                    </StackPanel>

                    <TextBlock x:Name="CustomRulesPathHint"
                               Grid.Row="8"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               TextWrapping="Wrap" />
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,0,16,14">
            <Button Content="取消"
                    Width="80" Height="34" Margin="0,0,12,0"
                    FontSize="13" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                    BorderBrush="{DynamicResource ThemeBorder}" Click="Cancel_Click" Cursor="Hand" />
            <Button Content="保存"
                    Width="80" Height="34"
                    FontSize="13" Background="{DynamicResource AccentBg}" Foreground="{DynamicResource AccentFg}"
                    BorderBrush="Transparent" FontWeight="SemiBold"
                    Click="Save_Click" Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
