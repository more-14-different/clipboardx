                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Foreground="{DynamicResource PrimaryText}"
                                   FontSize="12" Opacity="0.85" TextWrapping="Wrap"
                                   Text="{StaticResource ExperimentalFeaturesIntro}" />
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,2,0,0">
                            <TextBlock Text="资源管理器 · everything 筛选项" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}" />
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="{StaticResource ExperimentalTipExplorerEv}">
                                <TextBlock Text="当前文件夹内键入筛选" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                            <Label Content="?" Style="{StaticResource ExperimentalHelpGlyphLabel}"
                                   ToolTip="{StaticResource ExperimentalTipExplorerEv}" />
                        </StackPanel>
                        <Border Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ExplorerEverythingQuickFindCycle_Click"
                                ToolTip="{StaticResource ExperimentalTipExplorerEv}">
                            <TextBlock x:Name="ExplorerEverythingQuickFindText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="选中搜索结果后的操作：在资源管理器内就地导航选中文件，或直接打开前台文件对话框跳转到该路径。">
                                <TextBlock Text="选中操作" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                        </StackPanel>
                        <Border Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Width="140"
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="10,7"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBorder}"
                                Cursor="Hand" MouseLeftButtonUp="ExplorerQuickFindOpenModeCycle_Click"
                                ToolTip="选中搜索结果后的操作模式">
                            <TextBlock x:Name="ExplorerQuickFindOpenModeText" Foreground="{DynamicResource PrimaryText}" FontSize="14"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Row="8" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="Transparent" Padding="0,4" ToolTip="everything（Everything IPC）单次最多返回条数（1～2000）。">
                                <TextBlock Text="筛选最大条数" Foreground="{DynamicResource PrimaryText}" FontSize="14" />
                            </Border>
                        </StackPanel>
                        <TextBox x:Name="ExplorerEverythingMaxResultsBox" Grid.Row="8" Grid.Column="1"
                                 HorizontalAlignment="Right" Width="140"
                                 FontSize="14" Padding="8,6"
                                 ToolTip="everything（Everything IPC）单次最多返回条数（1～2000）。"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource ThemeBorder}" CaretBrush="{DynamicResource PrimaryText}" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="CustomDialogTab" Header="自定义文件对话框">
                <Grid Margin="16,12,16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" MinHeight="160" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Foreground="{DynamicResource PrimaryText}"
                               TextWrapping="Wrap"
                               Text="针对内置识别为「无」的文件对话框：按窗口类名与进程名匹配。导入/导出为 JSON；合并导入时相同键的规则会被覆盖。探测向导也可从托盘菜单运行。" />

                    <ListBox x:Name="CustomRulesList"
                             Grid.Row="2"
                             Foreground="{DynamicResource PrimaryText}"
                             Background="{DynamicResource SurfaceBrush}"
                             BorderBrush="{DynamicResource ThemeBorder}"
                             DisplayMemberPath="SummaryLine" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button Content="删除所选"
                                Padding="12,6" MinWidth="100"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleDelete_Click" Cursor="Hand" />
                        <Button Content="运行探测向导…"
                                Padding="12,6" MinWidth="120" Margin="10,0,0,0"
                                Background="{DynamicResource AccentBg}"
                                Foreground="{DynamicResource AccentFg}"
                                BorderBrush="Transparent"
                                Click="CustomRuleWizard_Click" Cursor="Hand" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                        <Button Content="导入（合并）"
                                Padding="10,6" MinWidth="100"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleImportMerge_Click" Cursor="Hand" />
                        <Button Content="导入（替换）"
                                Padding="10,6" MinWidth="100" Margin="8,0,0,0"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleImportReplace_Click" Cursor="Hand" />
                        <Button Content="导出全部…"
                                Padding="10,6" MinWidth="100" Margin="8,0,0,0"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryText}"
                                BorderBrush="{DynamicResource ThemeBorder}"
                                Click="CustomRuleExport_Click" Cursor="Hand" />
                    </StackPanel>

                    <TextBlock x:Name="CustomRulesPathHint"
                               Grid.Row="8"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               TextWrapping="Wrap" />
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Background="{DynamicResource FooterBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ThemeSeparator}"
                Padding="16,12,16,14">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="取消"
                        Width="80" Height="34" Margin="0,0,12,0"
                        FontSize="13" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryText}"
                        BorderBrush="{DynamicResource ThemeBorder}" Click="Cancel_Click" Cursor="Hand" />
                <Button Content="保存"
                        Width="80" Height="34"
                        FontSize="13" Background="{DynamicResource AccentBg}" Foreground="{DynamicResource AccentFg}"
                        BorderBrush="Transparent" FontWeight="SemiBold"
                        Click="Save_Click" Cursor="Hand" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
