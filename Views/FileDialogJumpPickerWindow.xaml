<Window x:Class="ClipboardManager.FileDialogJumpPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClipboardManager"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Width="520"
        MinWidth="280"
        MinHeight="200"
        SizeToContent="Height"
        MaxHeight="560"
        ShowActivated="True"
        Title="ClipboardX — 跳转到文件夹">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedPopupStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainBorder" Background="{DynamicResource PopupBgBrush}" CornerRadius="12" Margin="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="16,14,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="跳转到文件夹" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="BtnAddCurrentToFavorites" Grid.Column="1"
                            Content="⭐ 收藏当前路径" FontSize="11"
                            Padding="8,4" Margin="8,0,0,0"
                            Cursor="Hand"
                            Click="BtnAddCurrentToFavorites_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource MutedText}"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip="将文件对话框当前所在目录加入收藏"/>
                </Grid>

                <Border Grid.Row="1" Height="1" VerticalAlignment="Bottom" Background="{DynamicResource ThemeSeparator}"/>

                <Border x:Name="SearchBarPanel" Grid.Row="2" Visibility="Collapsed"
                        Margin="8,8,8,4" Padding="10,8" Background="{DynamicResource SurfaceBrush}" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SearchTextBlock" Grid.Column="1" Foreground="{DynamicResource PrimaryText}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SearchCountText" Grid.Column="2" Foreground="{DynamicResource SecondaryText}"
                                   FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="FileJumpHintText" Grid.Row="3" Margin="16,6,16,4" TextWrapping="Wrap" FontSize="10"
                           Foreground="{DynamicResource MutedText}"/>

                <ListBox x:Name="ItemsList" Grid.Row="4" Margin="4,0,4,0"
                         Background="Transparent"
                         BorderThickness="0"
                         FocusVisualStyle="{x:Null}"
                         Padding="4"
                         MaxHeight="380"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.ScrollChanged="ItemsList_ScrollChanged"
                         PreviewMouseLeftButtonUp="ItemsList_OnPreviewMouseLeftButtonUp"
                         PreviewMouseRightButtonUp="ItemsList_PreviewMouseRightButtonUp">
                    <ListBox.ContextMenu>
                        <ContextMenu x:Name="JumpRowContextMenu" Opened="JumpRowContextMenu_Opened">
                            <MenuItem x:Name="CtxAddFavorite" Header="⭐ 加入收藏" Click="CtxAddFavorite_Click"/>
                            <MenuItem x:Name="CtxRemoveFavorite" Header="移除收藏" Click="CtxRemoveFavorite_Click"/>
                            <MenuItem x:Name="CtxEditPhrase" Header="✎ 修改关键词…" Click="CtxEditPhrase_Click"/>
                            <Separator/>
                            <MenuItem x:Name="CtxRemoveRecentFolder" Header="移除常用路径" Click="CtxRemoveRecentFolder_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:FileJumpPickerRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding IndexLabel}"
                                           FontSize="10" TextAlignment="Center"
                                           Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding TypeIcon}"
                                           FontSize="14" Width="26" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <local:SearchHighlightTextBlock DisplayText="{Binding PreviewLine}"
                                                                   HighlightQuery="{Binding HighlightSearchQuery, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   FontSizeOverride="12"
                                                                   UseMutedBase="True"/>
                                    <local:SearchHighlightTextBlock DisplayText="{Binding PathLineTruncated}"
                                                                   ToolTip="{Binding PathLine}"
                                                                   HighlightQuery="{Binding HighlightSearchQuery, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   FontSizeOverride="13"
                                                                   UseMutedBase="False"/>
                                    <local:SearchHighlightTextBlock DisplayText="{Binding SubInfo, TargetNullValue=''}"
                                                                   HighlightQuery="{Binding HighlightSearchQuery, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   FontSizeOverride="10"
                                                                   UseMutedBase="True"
                                                                   Margin="0,2,0,0"
                                                                   Visibility="{Binding SubInfoVisibility}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="5" Padding="14,8" Background="{DynamicResource FooterBrush}"
                        CornerRadius="0,0,12,12">
                    <TextBlock x:Name="FooterHintsText" Foreground="{DynamicResource MutedText}" FontSize="10"
                               HorizontalAlignment="Left" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                               TextAlignment="Left" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    <!-- 右下角 resize grip 指示器 -->
    <Canvas Width="14" Height="14"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,14,14" IsHitTestVisible="False" Opacity="0.25">
        <Line X1="3" Y1="11" X2="11" Y2="3" Stroke="{DynamicResource SecondaryText}" StrokeThickness="1"/>
        <Line X1="7" Y1="11" X2="11" Y2="7" Stroke="{DynamicResource SecondaryText}" StrokeThickness="1"/>
    </Canvas>
    </Grid>
</Window>
