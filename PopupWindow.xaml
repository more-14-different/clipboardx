<Window x:Class="ClipboardManager.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Width="420"
        SizeToContent="Height"
        MaxHeight="560">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="12,9"
                                Margin="4,1"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBd"
                                                        Background="{DynamicResource SecondaryText}"
                                                        CornerRadius="3"
                                                        Opacity="0.3"
                                                        Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Opacity" Value="0.55"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
    <Border x:Name="MainBorder" Background="{DynamicResource PopupBgBrush}" CornerRadius="12" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,14,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Cursor="SizeAll"
                            MouseLeftButtonDown="Header_DragStart">
                    <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="剪切板历史" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ItemCountText" FontSize="12" Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center" Margin="8,1,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="Transparent" Cursor="Hand" Margin="0,0,10,0"
                        MouseLeftButtonUp="Settings_Click" ToolTip="设置">
                    <TextBlock Text="⚙" FontSize="14" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                </Border>
                <!-- Type filter button -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                        Padding="8,3" Cursor="Hand" MouseLeftButtonUp="TypeFilter_Click">
                    <TextBlock x:Name="TypeFilterText" Text="全部" FontSize="11"
                               Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Background="{DynamicResource ThemeSeparator}"/>

            <!-- Search Bar -->
            <Border x:Name="SearchBarPanel" Grid.Row="1" Visibility="Collapsed"
                    Margin="8,8,8,4" Padding="10,8" Background="{DynamicResource SurfaceBrush}" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SearchTextBlock" Grid.Column="1" Foreground="{DynamicResource PrimaryText}"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SearchCountText" Grid.Column="2" Foreground="{DynamicResource SecondaryText}"
                               FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- Items List -->
            <Grid Grid.Row="2">
                <ListBox x:Name="ItemsList"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="420"
                         Padding="4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.ScrollChanged="ItemsList_ScrollChanged"
                         PreviewMouseLeftButtonUp="ItemsList_PreviewMouseUp"
                         PreviewMouseRightButtonUp="ItemsList_PreviewMouseRightUp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding IndexLabel}"
                                           FontSize="10" TextAlignment="Center"
                                           Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" Text="{Binding TypeIcon}"
                                           FontSize="15" Width="28" TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IconVisibility}"/>

                                <Border Grid.Column="1" Width="48" Height="36"
                                        CornerRadius="4" Margin="0,0,4,0"
                                        Visibility="{Binding ThumbnailVisibility}">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,8,0">
                                    <TextBlock Text="{Binding Preview}"
                                               Foreground="{DynamicResource PrimaryText}" FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SubInfo}"
                                               Foreground="{DynamicResource MutedText}" FontSize="10"
                                               Margin="0,2,0,0" Visibility="{Binding SubInfoVisibility}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="{Binding TimeAgo}"
                                           Foreground="{DynamicResource SecondaryText}" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel x:Name="EmptyHint" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,30" Visibility="Visible">
                    <TextBlock x:Name="EmptyIcon" Text="📭" FontSize="28" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyText" Text="暂无剪切板记录" Foreground="{DynamicResource SecondaryText}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="EmptySubText" Text="复制一些文本即可开始" Foreground="{DynamicResource MutedText}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="3" Padding="14,8" Background="{DynamicResource FooterBrush}" CornerRadius="0,0,12,12">
                <TextBlock x:Name="FooterHints" Foreground="{DynamicResource MutedText}" FontSize="10"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- Context Menu Popup -->
            <Popup x:Name="ContextPopup" StaysOpen="False" Placement="Mouse"
                   AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                        Padding="4" Margin="8" BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeBorder}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Padding="10,7" CornerRadius="6" Cursor="Hand"
                                MouseLeftButtonUp="CtxPaste_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="📋 粘贴" Foreground="{DynamicResource PrimaryText}" FontSize="13"/>
                        </Border>
                        <Border Padding="10,7" CornerRadius="6" Cursor="Hand"
                                MouseLeftButtonUp="CtxShortcut_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock x:Name="CtxShortcutText" Text="⚡ 设为快捷短语" Foreground="{DynamicResource PrimaryText}" FontSize="13"/>
                        </Border>
                        <Border Height="1" Background="{DynamicResource ThemeSeparator}" Margin="4,2"/>
                        <Border Padding="10,7" CornerRadius="6" Cursor="Hand"
                                MouseLeftButtonUp="CtxDelete_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🗑 删除" Foreground="{DynamicResource SecondaryText}" FontSize="13"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>

    <!-- Phrase Edit Side Panel -->
    <Popup x:Name="PhraseEditPopup" StaysOpen="True" Placement="Right"
           PlacementTarget="{Binding ElementName=MainBorder}"
           AllowsTransparency="True" HorizontalOffset="-12" VerticalOffset="0">
        <Border Background="{DynamicResource PopupBgBrush}" CornerRadius="12"
                Padding="16" Margin="8,16,16,16" Width="240">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.45" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="⚡ 快捷短语" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>
                <TextBlock x:Name="PhrasePreview" FontSize="12" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,12" MaxHeight="36"
                           TextWrapping="Wrap"/>
                <TextBlock Text="短语关键词" FontSize="12"
                           Foreground="{DynamicResource MutedText}" Margin="0,0,0,6"/>
                <TextBox x:Name="PhraseEditBox" FontSize="13" Padding="8,6"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource PrimaryText}"
                         BorderBrush="{DynamicResource ThemeBorder}"
                         CaretBrush="{DynamicResource PrimaryText}"
                         KeyDown="PhraseEditBox_KeyDown"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Border Padding="10,6" CornerRadius="6" Cursor="Hand" Margin="0,0,8,0"
                            Background="{DynamicResource SurfaceBrush}"
                            MouseLeftButtonUp="PhraseCancel_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="取消" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                    </Border>
                    <Border Padding="10,6" CornerRadius="6" Cursor="Hand"
                            MouseLeftButtonUp="PhraseConfirm_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AccentBg}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="确定" FontSize="12" Foreground="{DynamicResource AccentFg}" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Popup>
    </Grid>
</Window>
