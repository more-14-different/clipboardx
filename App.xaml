<Application x:Class="ClipboardManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <!-- Default dark theme (overwritten at runtime by ThemeManager) -->
        <SolidColorBrush x:Key="PopupBgBrush" Color="#F21E1E2E"/>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#313244"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#313244"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#45475A"/>
        <SolidColorBrush x:Key="FooterBrush" Color="#181825"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#6C7086"/>
        <SolidColorBrush x:Key="MutedText" Color="#585B70"/>
        <SolidColorBrush x:Key="HintText" Color="#7F849C"/>
        <SolidColorBrush x:Key="AccentBg" Color="#89B4FA"/>
        <SolidColorBrush x:Key="AccentFg" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="ThemeBorder" Color="#585B70"/>
        <SolidColorBrush x:Key="ThemeSeparator" Color="#313244"/>
        <SolidColorBrush x:Key="DangerBg" Color="#F38BA8"/>
    </Application.Resources>
</Application>
